-- Remove old tables if they exist
drop table if exists entries;
drop table if exists profiles;

-- Create the entries table
create table entries (
  id          uuid primary key default gen_random_uuid(),
  player_id   text not null,
  player_name text not null,
  week        integer not null,
  item_name   text not null,
  is_bonus    boolean default false,
  points      integer default 10,
  created_at  timestamp with time zone default now()
);

-- Turn on security
alter table entries enable row level security;

-- Allow anyone to read entries (for the leaderboard)
create policy "Anyone can read entries"
  on entries for select
  using (true);

-- Allow anyone to add entries
create policy "Anyone can insert entries"
  on entries for insert
  with check (true);

-- Allow anyone to delete entries (needed to update your picks)
create policy "Anyone can delete entries"
  on entries for delete
  using (true);
